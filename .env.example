# PostgreSQL connection string (async, used by SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_content_db

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Groq API key (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# LLM model name used via LangChain's ChatGroq integration
LLM_MODEL=llama-3.3-70b-versatile

# Celery broker (RabbitMQ) and result backend (Redis) -- added in Task 2
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0